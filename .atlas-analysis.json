  "keyFeatures": [
    "Structured course creation with chapters and lessons",
    "Live classes via Zoom and Google Meet integration",
    "Quizzes with single-choice, multiple-choice, and open-ended questions",
    "Assignment submission and review workflow",
    "Course and batch certifications with custom templates",
    "Batch-based learner grouping with timetables",
    "Programming exercises with code execution",
    "SCORM content support",
    "Payments and billing integration",
    "Job board for certified learners",
    "Full-text search with SQLite index",
    "Plugin system for profile tabs and page extensions"
  ],
  "publicApiSurface": [
    "GET/POST /api/method/lms.lms.api.get_user_info",
    "GET/POST /api/method/lms.lms.api.get_translations",
    "GET/POST /api/method/lms.lms.api.validate_billing_access",
    "LMS Roles: Moderator, Course Creator, Batch Evaluator, LMS Student",
    "Plugin: PageExtension (render_header, render_footer)",
    "Plugin: ProfileTab (get_title, render)",
    "Markdown Macros: Exercise, Quiz, YouTubeVideo, Video, Assignment, Embed, Audio, PDF",
    "Hooks: lms_lesson_page_extensions, profile_tabs, lms_markdown_macro_renderers"
  ]
